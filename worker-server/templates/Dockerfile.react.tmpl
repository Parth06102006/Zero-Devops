FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci --ignore-scripts

COPY . .
RUN npm run build

FROM node:20-alpine

WORKDIR /app

ENV NODE_ENV=production

COPY package*.json ./
RUN npm ci --ignore-scripts --omit=dev

COPY --from=builder /app/build ./build

EXPOSE 3000

CMD ["npm", "start"]
